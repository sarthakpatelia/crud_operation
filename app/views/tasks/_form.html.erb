<%= form_with(model: task, local: true) do |form| %>
  <% if task.errors.any? %>
    <div class="alert alert-danger">
      <h4><%= pluralize(task.errors.count, "error") %> prevented this task from being saved:</h4>
      <ul>
        <% task.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
   
    <%= form.text_field :user_id, id: :task_user_id,class: "form-control", value:current_user.id, type: :hidden  %>
  </div>

  <div class="mb-3">
    <%= form.label :first_name, "First Name" %>
    <%= form.text_field :first_name, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= form.label :last_name, "Last Name" %>
    <%= form.text_field :last_name, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= form.label :email, "Email" %>
    <%= form.email_field :email, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= form.label :phone, "Phone" %>
    <%= form.text_field :phone, class: "form-control" %>
  </div>

  <div class="field form-group">
    <%= form.label :description, "Task Description" %>
    <%= form.text_area :description, class:"form-control", placeholer:"Add Task description"%>
  </div>

  <div class="mb-3">
    <%= form.submit "Save Task", class: "btn btn-primary" %>
    <%= link_to "Back", tasks_path, class: "btn btn-secondary ms-2" %>
  </div>
<% end %>