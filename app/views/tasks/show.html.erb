<p class="text-success"><%= notice %></p>

<div class="container mt-4">
  <div class="row justify-content-center">
    <div class="col-md-6">

      <div class="card shadow">
        <div class="card-header bg-dark text-white">
          <h4>Task Details</h4>
        </div>

        <div class="card-body">

          <p>
            <strong>First Name:</strong>
            <%= @task.first_name %>
          </p>

          <p>
            <strong>Last Name:</strong>
            <%= @task.last_name %>
          </p>

          <p>
            <strong>Email:</strong>
            <%= @task.email %>
          </p>

          <p>
            <strong>Phone:</strong>
            <%= @task.phone %>
          </p>

          <p>
            <strong>Description:</strong>
            <%= @task.description %>
          </p>

        </div>

        <div class="card-footer">

          <%= link_to "Edit", edit_task_path(@task), class:"btn btn-warning btn-sm" %>
          <%= link_to "Back", tasks_path, class:"btn btn-secondary btn-sm" %>
          <%= button_to "Delete", delete_task_path(@task), method: :delete, data: { turbo_confirm: "Are you sure you want to delete this task?" }, class:"btn btn-sm btn-danger" %>

        </div>
      </div>

    </div>
  </div>
</div>