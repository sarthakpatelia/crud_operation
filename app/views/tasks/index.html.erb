<p class="text-success"><%= notice %></p>

<% content_for :title, "Tasks" %>

<h1>Tasks</h1>

<div id="tasks">
  <table class="table table-striped table-hover">
    <thead class="table-dark">
      <tr>
        <th scope="col">User Id</th>
        <th scope="col">Full Name</th>
        <th scope="col">Email Id</th>
        <th scope="col">Phone</th>
        <th scope="col">Description</th>
        <th scope="col">Actions</th>
      </tr>
    </thead>

    <tbody>
      <% @tasks.each do |task| %>
        <tr>
          <td><%= task.id %></td>
          <td>
          <%= link_to task.first_name + ' ' +  task.last_name, task%></td>
          <td><%= task.email %></td>
          <td><%= task.phone %></td>
          <td><%= task.description %></td>
          <td>
            <%= link_to "Show", task, class: "btn btn-sm btn-primary" %>

            <% if user_signed_in? && task.user == current_user %>
              <%= link_to "Edit", edit_task_path(task), class: "btn btn-sm btn-warning" %>

              <%= link_to "Delete",
                  task,
                  data: { turbo_method: :delete, turbo_confirm: "Are you sure?" },
                  class: "btn btn-sm btn-danger" %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <% if user_signed_in? %>
    <%= link_to "New task", new_task_path, class: "btn btn-secondary mt-2" %>
  <% end %>
</div>
